# Copy to .env before `docker compose up`:  cp example.env .env
# All values have working defaults for local compose; only ANTHROPIC_API_KEY is
# worth setting for real LLM drafting.

# --- Anthropic (optional) ---
# Leave blank to use the worker's deterministic mock drafting (no network).
# When set, the worker drafts each criterion with Claude (claude-sonnet-class).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Postgres ---
POSTGRES_USER=vpat
POSTGRES_PASSWORD=vpat
POSTGRES_DB=vpat
# DATABASE_URL is assembled in docker-compose from the values above.

# --- AWS / LocalStack ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=vpat-artifacts
SCAN_QUEUE_NAME=vpat-scan-jobs
SCAN_DLQ_NAME=vpat-scan-jobs-dlq

# --- Web ---
# Where the browser reaches the API (host-published port). Baked into the SPA build.
VITE_API_URL=http://localhost:8080

# --- Auth0 SPA login (optional) ---
# When both values are set, the wizard requires Auth0 login before a report can be created.
# Keep the dev server on http://localhost:5173 to match the configured callback/logout/origin URLs.
VITE_AUTH0_DOMAIN=dev-5iepn3tlte3m2e34.us.auth0.com
VITE_AUTH0_CLIENT_ID=KBAAGVPWkdn78NWp4s1UqNtCWGz2tOML
VITE_AUTH0_AUDIENCE=https://api.vpatbuilder.com

# --- Auth0 API protection ---
# The Fastify API validates RS256 access tokens against this tenant and API identifier.
AUTH0_DOMAIN=dev-5iepn3tlte3m2e34.us.auth0.com
AUTH0_AUDIENCE=https://api.vpatbuilder.com

# Optional plan mapping for local/dev accounts when your token does not include a plan claim.
# Comma-separated email lists; everyone else defaults to starter.
GROWTH_PLAN_EMAILS=
ENTERPRISE_PLAN_EMAILS=

# --- Stripe Billing (optional) ---
# Hosted Checkout + Customer Portal for the modeled annual plans:
# Starter ($99/year) and Growth ($499/year). Enterprise remains contact-sales.
# APP_URL is the browser-visible web origin used for Checkout success/cancel returns.
APP_URL=http://localhost:5173
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
